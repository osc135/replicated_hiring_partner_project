# Required
OPENAI_API_KEY=your-openai-api-key-here
SECRET_KEY=change-this-to-a-random-string

# Optional - LangFuse observability
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com

# Database (used by docker-compose, usually don't need to change)
DATABASE_URL=postgresql://postgres:postgres@db:5432/bundle_analyzer
